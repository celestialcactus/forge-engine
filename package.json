{
  "name": "forge-engine",
  "version": "0.1.0",
  "description": "Drop-in enterprise agent coding system — spec-driven, constraint-enforced, auditable agent execution",
  "type": "module",
  "bin": {
    "forge": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "forge": "node dist/cli/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.1.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@inquirer/prompts": "^8.4.2",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "ai": "^4.0.0",
    "ai-sdk-ollama": "^3.0.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.6.2",
    "commander": "^12.0.0",
    "diff": "^7.0.0",
    "drizzle-orm": "^0.38.0",
    "env-paths": "^3.0.0",
    "execa": "^9.5.0",
    "figures": "^6.1.0",
    "ink": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "nanoid": "^5.0.0",
    "pino": "^9.0.0",
    "proper-lockfile": "^4.1.2",
    "strip-ansi": "^7.1.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT"
}
