{
  "name": "forge-engine",
  "version": "0.1.0",
  "description": "Sovereign-first, host-neutral agent runtime for developer workflows",
  "type": "module",
  "bin": {
    "forge": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.v1.json",
    "dev": "tsx src/cli.ts",
    "forge": "node dist/src/cli.js",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.v1.json --noEmit",
    "check": "npm run typecheck && npm test && npm run build",
    "smoke": "node dist/src/cli.js doctor --json && node dist/src/cli.js run smoke",
    "prebuild": "node scripts/clean.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "22.18.1",
    "tsx": "4.20.5"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "typescript": "5.9.2",
    "zod": "4.4.3"
  }
}
