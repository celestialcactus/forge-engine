{
  "name": "forge-engine",
  "version": "0.1.0",
  "description": "Sovereign-first, host-neutral agent runtime for developer workflows",
  "type": "module",
  "bin": {
    "forge": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.v1.json",
    "dev": "tsx src/cli.ts",
    "forge": "node dist/src/cli.js",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.v1.json --noEmit && tsc -p tsconfig.scripts.json",
    "check": "npm run typecheck && npm test && npm run build",
    "smoke": "node dist/src/cli.js doctor --json && node dist/src/cli.js run smoke",
    "rust:fmt": "cargo fmt --all -- --check",
    "rust:lint": "cargo clippy --workspace --all-targets --locked -- -D warnings",
    "rust:test": "cargo test --workspace --locked",
    "rust:build": "cargo build --workspace --locked",
    "rust:build:release": "cargo build --workspace --release --locked",
    "test:hybrid": "tsx --test tests/hybrid/**/*.hybrid.ts",
    "benchmark:hybrid": "tsx scripts/benchmark-hybrid.mts",
    "check:hybrid": "npm run rust:fmt && npm run rust:lint && npm run rust:test && npm run rust:build && npm run check && npm run test:hybrid",
    "prebuild": "node scripts/clean.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "22.18.1",
    "tsx": "4.20.5"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "typescript": "5.9.2",
    "zod": "4.4.3"
  }
}
